{
  "expo": {
    "name": "Coup'Laine",
    "slug": "coupe-laine",
    "description": "Compagnon quotidien du tondeur de mouton.",
    "version": "0.10.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "couplaine",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F4ED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.raphaelgauthier.couplaine",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pour centrer la carte sur votre position."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F4ED",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "fr.raphaelgauthier.couplaine",
      "versionCode": 6,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F4ED",
          "dark": {
            "backgroundColor": "#1A1612"
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      [
        "@maplibre/maplibre-react-native",
        {
          "android": {
            "downloadIntent": false
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "couplaine",
          "organization": "ravnkode"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a80d60c5-30f1-48aa-9d59-58e491ec7d9f"
      }
    },
    "owner": "ravnkode"
  }
}
