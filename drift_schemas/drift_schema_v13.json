  "fixed_sql": [
    {
      "name": "settings",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"settings\" (\"id\" INTEGER NOT NULL CHECK(\"id\" = 1), \"base_address_label\" TEXT NOT NULL, \"base_lat\" REAL NOT NULL, \"base_lon\" REAL NOT NULL, \"default_radius_km\" INTEGER NOT NULL DEFAULT 15, \"travel_fee_euros_per_bracket\" INTEGER NOT NULL DEFAULT 8, \"bracket_km\" INTEGER NOT NULL DEFAULT 10, \"theme_mode\" TEXT NOT NULL DEFAULT 'system', \"marker_default_color\" TEXT NOT NULL DEFAULT '#9CA3AF', \"marker_waiting_color\" TEXT NOT NULL DEFAULT '#EAB308', \"marker_scheduled_color\" TEXT NOT NULL DEFAULT '#65A30D', \"marker_done_color\" TEXT NOT NULL DEFAULT '#166534', \"marker_no_animals_color\" TEXT NOT NULL DEFAULT '#1F2937', \"marker_banned_color\" TEXT NOT NULL DEFAULT '#B91C1C', \"season_started_at\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "clients",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"clients\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"phones\" TEXT NOT NULL DEFAULT '[]', \"address_label\" TEXT NOT NULL, \"postcode\" TEXT NOT NULL, \"city\" TEXT NOT NULL, \"lat\" REAL NOT NULL, \"lon\" REAL NOT NULL, \"animals\" TEXT NOT NULL DEFAULT '[]', \"marker_color_hex\" TEXT NULL, \"is_waiting\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_waiting\" IN (0, 1)), \"last_intervention_date\" INTEGER NULL, \"needs_distance_recompute\" INTEGER NOT NULL DEFAULT 0 CHECK (\"needs_distance_recompute\" IN (0, 1)), \"is_banned\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_banned\" IN (0, 1)), \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "distance_matrix",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"distance_matrix\" (\"from_id\" INTEGER NOT NULL, \"to_id\" INTEGER NOT NULL, \"distance_meters\" INTEGER NOT NULL, \"duration_seconds\" INTEGER NOT NULL, \"computed_at\" INTEGER NOT NULL, PRIMARY KEY (\"from_id\", \"to_id\"));"
        }
      ]
    },
    {
      "name": "species",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"species\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"icon_key\" TEXT NULL, \"archived_at\" INTEGER NULL, \"created_at\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "animal_categories",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"animal_categories\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"species_id\" INTEGER NOT NULL REFERENCES species (id) ON DELETE CASCADE, \"name\" TEXT NOT NULL, \"archived_at\" INTEGER NULL, \"created_at\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "tours",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"tours\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"planned_date\" INTEGER NOT NULL, \"start_time_minutes\" INTEGER NOT NULL, \"status\" TEXT NOT NULL, \"total_distance_meters\" INTEGER NOT NULL, \"total_drive_seconds\" INTEGER NOT NULL, \"total_travel_fee_cents\" INTEGER NOT NULL, \"notes\" TEXT NULL, \"completed_at\" INTEGER NULL, \"created_at\" INTEGER NOT NULL, \"route_geometry\" TEXT NULL);"
        }
      ]
    },
    {
      "name": "tour_stops",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"tour_stops\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"tour_id\" INTEGER NOT NULL REFERENCES tours (id) ON DELETE CASCADE, \"client_id\" INTEGER NULL REFERENCES clients (id) ON DELETE SET NULL, \"client_name_snapshot\" TEXT NOT NULL, \"order_index\" INTEGER NOT NULL, \"estimated_arrival_minutes\" INTEGER NOT NULL, \"estimated_departure_minutes\" INTEGER NOT NULL, \"planned_prestations\" TEXT NOT NULL DEFAULT '[]', \"actual_prestations\" TEXT NULL, \"intervention_note\" TEXT NULL, \"fee_share_cents\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "manual_history_entries",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"manual_history_entries\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"client_id\" INTEGER NOT NULL REFERENCES clients (id) ON DELETE CASCADE, \"date\" INTEGER NOT NULL, \"prestations\" TEXT NOT NULL DEFAULT '[]', \"note\" TEXT NULL, \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "prestations",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"prestations\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"price_cents\" INTEGER NULL, \"minutes\" INTEGER NULL, \"category_id\" INTEGER NULL REFERENCES animal_categories (id) ON DELETE SET NULL, \"archived_at\" INTEGER NULL, \"created_at\" INTEGER NOT NULL);"
